    "react": "^18.3.1",
    "react-animation-on-scroll": "^5.1.0",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-tilty": "^3.0.0",
    "remark-directive": "^4.0.0",
